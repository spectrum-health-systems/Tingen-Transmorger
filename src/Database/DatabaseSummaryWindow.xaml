<Window
    x:Class="TingenTransmorger.Database.DatabaseSummaryWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:TingenTransmorger.Database"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="DatabaseSummaryWindow"
    Width="600"
    Height="450"
    mc:Ignorable="d">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border
            Grid.Column="0"
            Margin="8"
            Padding="12"
            Background="White"
            CornerRadius="6">
            <StackPanel>
                <TextBlock
                    Margin="0,0,0,12"
                    FontSize="18"
                    FontWeight="Bold"
                    Text="Visit Stats" />
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="pnlVisitStats" />
                </ScrollViewer>
            </StackPanel>
        </Border>

        <Border
            Grid.Column="1"
            Margin="8"
            Padding="12"
            Background="White"
            CornerRadius="6">
            <StackPanel>
                <TextBlock
                    Margin="0,0,0,12"
                    FontSize="18"
                    FontWeight="Bold"
                    Text="Message Failure" />
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="pnlMessageFailure" />
                </ScrollViewer>
            </StackPanel>
        </Border>
    </Grid>
</Window>
